# Copy to .env.local and fill in. All values are optional.

# ── Model ────────────────────────────────────────────────────────────────
# Option 1 (default): route through the Vercel AI Gateway (uses Claude).
#   Provide a gateway key, or run `eve link` to pull one.
# AI_GATEWAY_API_KEY=...

# Option 2: point at any Anthropic-compatible endpoint that supports tool
# calling (llama.cpp, a local proxy, etc.). When LLM_BASE_URL is set, agent.ts
# uses it instead of the gateway.
# LLM_BASE_URL=http://localhost:8080/v1
# LLM_API_KEY=local
# LLM_MODEL=your-model-name
# LLM_CONTEXT_TOKENS=131072

# Option 3: Gemini via the native @ai-sdk/google provider. Point GEMINI_BASE_URL
# at a Google Generative Language endpoint (or a compatible proxy); agent.ts
# appends /v1beta. When GEMINI_BASE_URL is set, it takes precedence.
# GEMINI_API_KEY=...
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_CONTEXT_TOKENS=1048576

# ── Memory ───────────────────────────────────────────────────────────────
# Where long-term memory is persisted. Defaults to ./memory-store.json
# (gitignored). Delete that file to reset the agent's memory.
# MEMORY_FILE=/absolute/path/to/memory-store.json
