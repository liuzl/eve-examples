# Copy to .env.local and fill in. All values are optional.

# ── Model ────────────────────────────────────────────────────────────────
# Option 1 (default): route through the Vercel AI Gateway (uses Claude).
#   Provide a gateway key, or run `eve link` to pull one.
# AI_GATEWAY_API_KEY=...

# Option 2: point at any Anthropic-compatible endpoint that supports tool
# calling (llama.cpp, a local proxy, etc.). When LLM_BASE_URL is set, agent.ts
# uses it instead of the gateway.
# LLM_BASE_URL=http://localhost:8080/v1
# LLM_API_KEY=local
# LLM_MODEL=your-model-name
# LLM_CONTEXT_TOKENS=131072

# ── Data ─────────────────────────────────────────────────────────────────
# Where lookup_host / search_incidents read from. Defaults to ./sample-data.
# OPLOG_DIR=/absolute/path/to/your/own/data
